# -------------------------------------------------------
# DATABASE
# Get a free PostgreSQL URL from: https://neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# -------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# -------------------------------------------------------
# AUTH SECRET — must be at least 32 random characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-secret-min-32-chars"

# -------------------------------------------------------
# ADMIN SEED — first admin user created on first API call
# -------------------------------------------------------
SEED_ADMIN_EMAIL="admin@nexcup.gg"
SEED_ADMIN_PASSWORD="replace-this-admin-password"
